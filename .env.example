# Leave DATABASE_URL unset on Railway until a real Postgres URL is available.
# For local development you can keep the SQLite fallback below.
DATABASE_URL=sqlite:///./editnest.db
SECRET_KEY=replace-this-with-a-long-random-secret
FRONTEND_URL=https://editnest.in
CORS_ALLOWED_ORIGINS=https://www.editnest.in,http://localhost:3000
APP_TIMEZONE=Asia/Kolkata
# Localhost/127.0.0.1 on any dev port is allowed by default in code.
# Optional: for Vercel preview deployments
# CORS_ALLOW_ORIGIN_REGEX=https://.*\\.vercel\\.app
ACCESS_TOKEN_EXPIRE_MINUTES=10080
API_KEY=replace-this-automation-key
ADMIN_EMAILS=you@example.com
# Optional private-access mode
AUTH_INVITE_ONLY=false
# Comma-separated exact emails that are allowed to sign up and log in
AUTH_ALLOWED_EMAILS=you@example.com
# Comma-separated domains like yourcompany.com
AUTH_ALLOWED_DOMAINS=
MAX_FILE_SIZE_MB=10
REMBG_MODEL_NAME=u2net
REMBG_POST_PROCESS_MASK=true
REMBG_ALPHA_MATTING=true
REMBG_ALPHA_MATTING_FOREGROUND_THRESHOLD=240
REMBG_ALPHA_MATTING_BACKGROUND_THRESHOLD=10
REMBG_ALPHA_MATTING_ERODE_SIZE=10
REMBG_MAX_PROCESSING_SIDE=2800
REMBG_ALPHA_MATTING_MAX_PIXELS=4500000
REMBG_LARGE_UPLOAD_SIZE_MB=4
REMBG_LARGE_IMAGE_PIXEL_THRESHOLD=4000000
REMBG_LARGE_IMAGE_MAX_SIDE=2200
OPENAI_API_KEY=
# Optional image model tuning
# OPENAI_IMAGE_MODEL=gpt-image-1.5
# OPENAI_IMAGE_QUALITY=medium
# OPENAI_IMAGE_SIZE=1024x1024
